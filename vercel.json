{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    { "source": "/data.json", "destination": "/api/data", "permanent": false },
    { "source": "/data.js", "destination": "/api/data", "permanent": false }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [ { "key": "Cache-Control", "value": "no-store" } ] }
  ],
  "crons": [
    { "path": "/api/digest", "schedule": "0 13 * * *" },
    { "path": "/api/data?regen=1", "schedule": "0 * * * *" }
  ]
}
